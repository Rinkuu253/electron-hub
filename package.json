{
  "name": "electron-hub",
  "version": "1.0.0",
  "description": "Electron Hub",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"electron .\"",
    "build-vue": "vite build",
    "start": "electron-forge start",
    "build": "npm run build-vue && electron-builder --win",
    "package": "npm run build-vue && electron-forge package",
    "make": "npm run build-vue && electron-forge make"
  },
  "author": "Chrysan",
  "build": {
    "appId": "com.electron.electron-hub",
    "win": {
      "target": "portable"
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "23.1.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "vue": "^3.5.31"
  }
}
